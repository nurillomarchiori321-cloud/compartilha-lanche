<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Início - Compartilha Lanche</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-egg-fried"></i> Compartilha Lanche
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house"></i> Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/snacks"><i class="bi bi-list-ul"></i> Lanches</a>
                    </li>
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/snacks/new"><i class="bi bi-plus-circle"></i> Novo Lanche</a>
                        </li>
                        <li class="nav-item">
                            <span class="nav-link text-warning"><i class="bi bi-person-circle"></i> Olá, <%= user.name %></span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/register"><i class="bi bi-person-plus"></i> Cadastrar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main class="container py-4">
        <div class="page-header text-center">
            <h1><i class="bi bi-egg-fried"></i> Compartilha Lanche</h1>
            <p class="lead">Organize seu lanche coletivo de forma simples e colaborativa!</p>
        </div>

        <div class="row g-4 mt-3">
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-person-plus display-1 text-success"></i>
                        <h5 class="card-title mt-3">Cadastre-se</h5>
                        <p class="card-text text-muted">Crie sua conta para participar da organização dos lanches.</p>
                        <a href="/register" class="btn btn-success-custom">Cadastrar</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-egg display-1 text-warning"></i>
                        <h5 class="card-title mt-3">Compartilhe</h5>
                        <p class="card-text text-muted">Informe o lanche que você vai levar e evite repetições.</p>
                        <a href="/snacks" class="btn btn-outline-success-custom">Ver Lanches</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="card-body">
                        <i class="bi bi-people display-1 text-primary"></i>
                        <h5 class="card-title mt-3">Colabore</h5>
                        <p class="card-text text-muted">Veja o que cada um vai levar e organize seu lanche.</p>
                        <a href="/login" class="btn btn-outline-success-custom">Entrar</a>
                    </div>
                </div>
            </div>
        </div>

        <% if (snacks && snacks.length > 0) { %>
            <div class="mt-5">
                <h3 class="text-center mb-4 text-success fw-bold">
                    <i class="bi bi-list-ul"></i> Últimas Contribuições
                </h3>
                <div class="list-group">
                    <% snacks.forEach(snack => { %>
                        <div class="snack-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong><%= snack.item %></strong>
                                <span class="badge-date ms-2"><i class="bi bi-calendar3"></i> <%= snack.date %></span>
                            </div>
                            <span class="badge-user"><i class="bi bi-person"></i> <%= snack.User ? snack.User.name : 'Usuário' %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        <% } %>
    </main>

    <!-- FOOTER -->
    <footer class="footer text-center py-3 mt-4">
        <div class="container">
            <p class="text-muted mb-0">🍽️ Compartilha Lanche &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>