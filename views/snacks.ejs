<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lanches - Compartilha Lanche</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-egg-fried"></i> Compartilha Lanche
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house"></i> Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/snacks"><i class="bi bi-list-ul"></i> Lanches</a>
                    </li>
                    <% if (user) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/snacks/new"><i class="bi bi-plus-circle"></i> Novo Lanche</a>
                        </li>
                        <li class="nav-item">
                            <span class="nav-link text-warning"><i class="bi bi-person-circle"></i> Olá, <%= user.name %></span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/register"><i class="bi bi-person-plus"></i> Cadastrar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Login</a>
                        </li>
                    <% } %>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-success fw-bold">
                <i class="bi bi-list-ul"></i> Contribuições
            </h2>
            <% if (user) { %>
                <a href="/snacks/new" class="btn btn-success-custom">
                    <i class="bi bi-plus-circle"></i> Novo Lanche
                </a>
            <% } %>
        </div>

        <% if (snacks && snacks.length > 0) { %>
            <div class="row g-4">
                <% snacks.forEach(snack => { %>
                    <div class="col-md-6 col-lg-4">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-body">
                                <h5 class="card-title text-success fw-bold">
                                    <i class="bi bi-egg"></i> <%= snack.item %>
                                </h5>
                                <p class="card-text text-muted">
                                    <i class="bi bi-calendar3"></i> <strong><%= snack.date %></strong><br>
                                    <i class="bi bi-person"></i> <%= snack.User ? snack.User.name : 'Usuário' %>
                                </p>
                            </div>
                            <% if (user && user.id === snack.userId) { %>
                                <div class="card-footer bg-transparent border-0 d-flex gap-2">
                                    <a href="/snacks/<%= snack.id %>/edit" class="btn btn-warning btn-sm flex-grow-1">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                    <form action="/snacks/<%= snack.id %>/delete" method="POST" class="flex-grow-1">
                                        <button type="submit" class="btn btn-danger btn-sm w-100" onclick="return confirm('Tem certeza?')">
                                            <i class="bi bi-trash"></i> Excluir
                                        </button>
                                    </form>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-5">
                <i class="bi bi-egg display-1 text-muted"></i>
                <p class="lead mt-3 text-muted">Nenhuma contribuição ainda.</p>
                <% if (user) { %>
                    <a href="/snacks/new" class="btn btn-success-custom">
                        <i class="bi bi-plus-circle"></i> Seja o primeiro a contribuir!
                    </a>
                <% } else { %>
                    <a href="/login" class="btn btn-success-custom">
                        <i class="bi bi-box-arrow-in-right"></i> Faça login para contribuir
                    </a>
                <% } %>
            </div>
        <% } %>
    </main>

    <!-- FOOTER -->
    <footer class="footer text-center py-3 mt-4">
        <div class="container">
            <p class="text-muted mb-0">🍽️ Compartilha Lanche &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>