<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novo Lanche - Compartilha Lanche</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-egg-fried"></i> Compartilha Lanche
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="bi bi-house"></i> Início</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/snacks"><i class="bi bi-list-ul"></i> Lanches</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/snacks/new"><i class="bi bi-plus-circle"></i> Novo Lanche</a>
                    </li>
                    <li class="nav-item">
                        <span class="nav-link text-warning"><i class="bi bi-person-circle"></i> Olá, <%= user.name %></span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        <h2 class="mb-4 text-success fw-bold">
                            <i class="bi bi-plus-circle"></i> Novo Lanche
                        </h2>
                        
                        <% if (message) { %>
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-circle"></i> <%= message %>
                            </div>
                        <% } %>
                        
                        <form action="/snacks" method="POST">
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-egg"></i> Item
                                </label>
                                <input type="text" name="item" class="form-control" placeholder="Ex: Pizza, Refrigerante..." required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    <i class="bi bi-calendar3"></i> Data
                                </label>
                                <input type="date" name="date" class="form-control" required>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success-custom flex-grow-1">
                                    <i class="bi bi-check-circle"></i> Salvar
                                </button>
                                <a href="/snacks" class="btn btn-outline-secondary">
                                    <i class="bi bi-x-circle"></i> Cancelar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="footer text-center py-3 mt-4">
        <div class="container">
            <p class="text-muted mb-0">🍽️ Compartilha Lanche &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>