<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Erro - Compartilha Lanche</title>
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="bi bi-egg-fried"></i> Compartilha Lanche
            </a>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-5">
                        <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                        <h1 class="display-4 fw-bold text-danger">Erro <%= status %></h1>
                        <p class="lead text-muted"><%= message %></p>
                        <a href="/" class="btn btn-success-custom">
                            <i class="bi bi-house"></i> Voltar ao início
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="footer text-center py-3 mt-4">
        <div class="container">
            <p class="text-muted mb-0">🍽️ Compartilha Lanche &copy; 2026</p>
        </div>
    </footer>

    <script src="/js/bootstrap.bundle.min.js"></script>
</body>
</html>